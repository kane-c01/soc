# =========================================================
# SocialRouter — apply-form backend (Feishu group-chat bot)
# Copy to `.env.local` and fill in real values. NEVER commit .env.local.
# =========================================================

# REQUIRED — Feishu group-chat custom bot webhook.
# Create in: 飞书群 → 设置 → 群机器人 → 添加 → 自定义机器人 → 复制 webhook 地址.
FEISHU_NOTIFY_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/fc907254-2b86-49f0-ad4d-35fff5a77634

# OPTIONAL — only fill this if you turned on "签名校验" on the bot.
FEISHU_NOTIFY_SECRET=
